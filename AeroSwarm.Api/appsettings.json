{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5501",
  "Jwt": {
    "Key": "AeroSwarm_SuperSecret_Key_2025_MustBe32Chars!",
    "Issuer": "AeroSwarmApi",
    "Audience": "AeroSwarmClient",
    "ExpiresInMinutes": 480
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=aeroswarm.db"
  },
  "Swarm": {
    "DroneCount": 5,
    "IpTemplate": "127.0.0.1",
    "IpStart": 1,
    "UdpPort": 14550,
    "UdpPorts": [14550, 14560, 14570, 14580, 14590],
    "BindHost": "0.0.0.0",
    "HeartbeatIntervalSec": 1.0,
    "DropoutThresholdSec": 3.0,
    "TelemetryPersistIntervalSec": 5.0,
    "LowVoltagePerCell": 3.30,
    "CriticalVoltagePerCell": 3.20,
    "LiPoCellCount": 1
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/aeroswarm-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId" ]
  }
}
